# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Postgres (required for Prisma) ---
# Use the Supabase "Connection string" (Transaction pooler URL is recommended for serverless)
DATABASE_URL="postgresql://postgres.YOUR-PROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection used for migrations (not pooled)
DIRECT_URL="postgresql://postgres.YOUR-PROJECT:[YOUR-PASSWORD]@aws-0-REGION.pooler.supabase.com:5432/postgres"

# --- Email (optional; falls back to no-op logging if unset) ---
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Builder Portal <noreply@example.com>"

# --- Wrike (optional; falls back to stub client if unset) ---
WRIKE_TOKEN=""
WRIKE_BASE_URL="https://www.wrike.com/api/v4"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_NAME="Builder Portal"
